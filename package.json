{
  "name": "almighty-image-extension",
  "displayName": "Almighty image extension",
  "version": "0.0.1",
  "description": "A basic Plasmo extension.",
  "author": "https://github.com/process1024",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "ahooks": "^3.8.0",
    "classnames": "^2.5.1",
    "lodash-es": "^4.17.21",
    "plasmo": "0.86.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-if": "^4.1.5",
    "react-selecto": "^1.26.3",
    "vue": "^3.4.29"
  },
  "devDependencies": {
    "@eslint/compat": "^1.1.0",
    "@eslint/js": "^9.6.0",
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "eslint": "9.x",
    "eslint-plugin-react": "^7.34.3",
    "globals": "^15.8.0",
    "prettier": "3.2.4",
    "typescript": "5.3.3",
    "typescript-eslint": "^7.15.0"
  },
  "manifest": {
    "web_accessible_resources": [
      {
        "resources": [
          "tabs/*"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "contextMenus",
      "tabs",
      "activeTab",
      "management"
    ]
  }
}
